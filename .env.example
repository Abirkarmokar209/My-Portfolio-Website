# ─────────────────────────────────────────────────────────────────
# Environment variables for my-portfolio
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# CHANGE_HERE: Your PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/portfolio"

# CHANGE_HERE: Your production domain (used for CORS & metadata)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ── Optional: Email notifications via SMTP ──────────────────────
# Leave blank to skip email notifications (messages still save to DB)

# CHANGE_HERE: Your SMTP provider host
SMTP_HOST=""
# CHANGE_HERE: SMTP port (usually 587 for TLS, 465 for SSL)
SMTP_PORT="587"
# CHANGE_HERE: Your SMTP username / sender address
SMTP_USER=""
# CHANGE_HERE: Your SMTP password or app-specific password
SMTP_PASS=""
# CHANGE_HERE: Email address to receive contact form notifications
NOTIFY_EMAIL="you@example.com"
